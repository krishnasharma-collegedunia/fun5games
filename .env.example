# fun5games.com — environment variables
# ==========================================================
# Copy this file to `.env.local` (git-ignored) and fill in
# real values. On the VPS, copy to `/var/www/fun5games-com/.env.local`.
# After editing, run `npm run build && pm2 reload fun5games-com`
# because NEXT_PUBLIC_* vars are baked in at build time.

# ─── Google AdSense ─────────────────────────────────────────
# Get the publisher ID from AdSense Dashboard → Account → Account
# information. Format: ca-pub-XXXXXXXXXXXXXXXX (16 digits).
# When UNSET, the AdSense script does not load and every slot
# falls back to Adcash (or nothing, if Adcash banner zones are
# also unset). Leave blank until Google approves the site.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Per-slot AdSense unit IDs. Each is the 10-digit number you see in
# AdSense Dashboard → Ads → By ad unit → [unit name] → "Ad unit ID".
# Create three responsive display ad units (one per variant below)
# and paste the slot IDs here. Leave blank to skip that variant.
NEXT_PUBLIC_ADSENSE_SLOT_BOTTOM=   # used by flagship 970x250 bottom slots
NEXT_PUBLIC_ADSENSE_SLOT_INLINE=   # used by 728x90 / 336x280 mid-content slots
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=  # used by 300x250 sidebar rectangles

# ─── Adcash (Banner Zones) ──────────────────────────────────
# Adcash Autotag (zone qdabofupyz in layout.js) delivers pop /
# interstitial / in-page-push formats sitewide. To fill static
# BANNER placements, create additional zones in adcash.myadcash.com:
#   Websites → fun5games.com → Create Zone → Format: "Banner" →
#   pick a size → save → copy the zoneId string.
# Paste zone IDs below. Any unset variant simply won't render.
# Once AdSense is approved + configured above, AdSense wins and
# these Adcash banner zones stop being used (Autotag continues).
NEXT_PUBLIC_ADCASH_BANNER_ZONE_BOTTOM=   # 970x250 or 728x90 bottom slot (game detail page)
NEXT_PUBLIC_ADCASH_BANNER_ZONE_INLINE=   # 728x90 / 336x280 mid-content slots (not used yet)
NEXT_PUBLIC_ADCASH_BANNER_ZONE_SIDEBAR=  # 300x250 sidebar rectangles (not used yet)
